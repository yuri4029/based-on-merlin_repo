#!/usr/bin/python3
# -*- coding: utf-8 -*-
"""
QORC (Quantum Optical Reservoir Computing) applied to NSL-KDD intrusion detection.

Pipeline (same architecture as qorc.ipynb, applied to tabular network data instead of MNIST):
  1) Load & encode NSL-KDD CSV (one-hot categoricals + numeric scaling)
  2) PCA -> n_modes components, normalized to [0, 1]
  3) Photonic circuit (precircuit + phase-shifter encoding + reservoir) -> quantum features
  4) Standardize quantum features
  5) Concatenate raw (scaled) tabular features + quantum features
  6) Train a linear classifier (nn.Linear) on top
"""

import os
import sys
import time
import math
import random
import logging
import datetime as dt
from pathlib import Path

import numpy as np
import pandas as pd
import torch
import torch.nn as nn
import matplotlib.pyplot as plt

from sklearn.decomposition import PCA
from sklearn.preprocessing import OneHotEncoder, StandardScaler
from sklearn.model_selection import train_test_split
from sklearn.metrics import classification_report, confusion_matrix, ConfusionMatrixDisplay

import perceval as pcvl
import merlin as ML

# --- Repo path resolution (works regardless of the notebook's cwd, e.g. New_algo/) ---
cwd = Path.cwd().resolve()


def _find_project_root(start: Path) -> Path:
    candidate = start
    for _ in range(6):
        if (candidate / "lib").exists() and (candidate / "configs").exists():
            return candidate
        if (candidate / "papers" / "QORC" / "lib").exists():
            return candidate / "papers" / "QORC"
        candidate = candidate.parent
    raise RuntimeError(f"Could not locate the QORC project root starting from {start}")


project_root = _find_project_root(cwd)
repo_root = project_root.parent.parent
for p in (repo_root, project_root):
    p_str = str(p)
    if p_str not in sys.path:
        sys.path.insert(0, p_str)

from lib.lib_datasets import tensor_dataset, get_dataloader, split_fold_numpy
from lib.lib_learning import get_device, model_eval, model_fit
from runtime_lib.logging_utils import configure_logging
from merlin.measurement.strategies import MeasurementStrategy, ComputationSpace


# =========================
# 1) Parameters
# =========================
n_photons = 3
n_modes = 20
seed = 42

# Dataset
csv_path = project_root / "network data" / "NSL_KDD_labeled.csv"
binary_task = True   # True: normal vs attack | False: multiclass attack type
test_size = 0.2
fold_index = 0
n_fold = 5

# Training
n_epochs = 100
batch_size = 100
learning_rate = 0.05
reduce_lr_patience = 10
reduce_lr_factor = 0.5
num_workers = 0
pin_memory = False
f_out_weights = "f_weights_out.pth"

# Other
b_no_bunching = True
device_name = "cpu"
outdir = project_root / "New_algo" / "outdir"


# =========================
# 2) Logging
# =========================
configure_logging("info")
logger = logging.getLogger(__name__)

timestamp = dt.datetime.now().strftime("%Y%m%d-%H%M%S")
run_dir = Path(outdir) / f"run_nslkdd_{timestamp}"
run_dir.mkdir(parents=True, exist_ok=True)
configure_logging("info", run_dir / "run.log")

storage_device = torch.device("cpu")
compute_device = get_device(device_name)

if seed >= 0:
    random.seed(seed)
    np.random.seed(seed)
    torch.manual_seed(seed)
    torch.cuda.manual_seed_all(seed)
    torch.backends.cudnn.deterministic = True
    torch.backends.cudnn.benchmark = False
torch.use_deterministic_algorithms(mode=False)

time_t1 = time.time()


# =========================
# 3) Load & encode NSL-KDD data
# =========================
logger.info("Loading NSL-KDD data from {}".format(csv_path))
df = pd.read_csv(csv_path)

categorical_cols = ["protocol_type", "service", "flag"]
target_col = "label"
feature_cols = [c for c in df.columns if c != target_col]
numeric_cols = [c for c in feature_cols if c not in categorical_cols]

if binary_task:
    y_raw = np.where(df[target_col] == "normal", 0, 1)
    class_names = ["normal", "attack"]
else:
    classes_sorted = sorted(df[target_col].unique())
    label_to_idx = {c: i for i, c in enumerate(classes_sorted)}
    y_raw = df[target_col].map(label_to_idx).to_numpy()
    class_names = classes_sorted
n_classes = len(class_names)

# One-hot encode categoricals, keep numeric as-is (scaled later)
ohe = OneHotEncoder(sparse_output=False, handle_unknown="ignore")
X_cat = ohe.fit_transform(df[categorical_cols])
X_num = df[numeric_cols].to_numpy(dtype=np.float32)
X_all = np.concatenate([X_num, X_cat], axis=1).astype(np.float32)

# Hold out a test split, then use split_fold_numpy for train/val like the original notebook
train_val_data, test_data, train_val_label, test_label = train_test_split(
    X_all, y_raw, test_size=test_size, random_state=seed, stratify=y_raw
)
val_label, val_data, train_label, train_data = split_fold_numpy(
    train_val_label, train_val_data, n_fold, fold_index, split_seed=seed
)

# Scale raw tabular features (fit on train only)
raw_scaler = StandardScaler()
train_data = raw_scaler.fit_transform(train_data).astype(np.float32)
val_data = raw_scaler.transform(val_data).astype(np.float32)
test_data = raw_scaler.transform(test_data).astype(np.float32)

n_features_raw = train_data.shape[1]
logger.info("Datasets sizes:")
logger.info("train: {}, val: {}, test: {}".format(train_data.shape, val_data.shape, test_data.shape))


# =========================
# 4) Quantum circuit (identical structure to qorc.ipynb)
# =========================
unitary = pcvl.Matrix.random_unitary(n_modes)
precircuit = pcvl.Unitary(unitary)
reservoir = precircuit.copy()

c_var = pcvl.Circuit(n_modes)
for i in range(n_modes):
    px = pcvl.P(f"px{i + 1}")
    c_var.add(i, pcvl.PS(px))

qorc_circuit = precircuit // c_var // reservoir

assert n_photons <= n_modes, "Too many photons versus modes."
step = (n_modes - 1) / (n_photons - 1) if n_photons > 1 else 0
qorc_input_state = [0] * n_modes
for k in range(n_photons):
    index = int(round(k * step))
    qorc_input_state[index] = 1

if b_no_bunching:
    qorc_output_size = math.comb(n_modes, n_photons)
    computation_space = ComputationSpace.UNBUNCHED
else:
    qorc_output_size = math.comb(n_photons + n_modes - 1, n_photons)
    computation_space = ComputationSpace.FOCK

logger.info("MerLin QuantumLayer creation:")
qorc_quantum_layer = ML.QuantumLayer(
    input_size=n_modes,
    circuit=qorc_circuit,
    trainable_parameters=[],
    input_parameters=["px"],
    input_state=qorc_input_state,
    measurement_strategy=MeasurementStrategy.probs(computation_space=computation_space),
    device=torch.device(device_name),
)
logger.info(str(qorc_quantum_layer))


# =========================
# 5) PCA -> [0,1] normalization -> quantum features
# =========================
pca = PCA(n_components=n_modes)
train_data_pca = pca.fit_transform(train_data)
val_data_pca = pca.transform(val_data)
test_data_pca = pca.transform(test_data)

pca_train_global_min = train_data_pca.min()
pca_train_global_max = train_data_pca.max()

def normalize_global_min_max(data, global_min, global_max):
    epsilon = 1e-8
    return (data - global_min) / (global_max - global_min + epsilon)

train_data_pca_norm = normalize_global_min_max(train_data_pca, pca_train_global_min, pca_train_global_max)
val_data_pca_norm = normalize_global_min_max(val_data_pca, pca_train_global_min, pca_train_global_max)
test_data_pca_norm = normalize_global_min_max(test_data_pca, pca_train_global_min, pca_train_global_max)

logger.info("Quantum features size: {}".format(qorc_output_size))
time_t2 = time.time()
train_data_qorc = qorc_quantum_layer(
    torch.tensor(train_data_pca_norm, dtype=torch.float32, device=compute_device)
)
val_data_qorc = qorc_quantum_layer(
    torch.tensor(val_data_pca_norm, dtype=torch.float32, device=compute_device)
)
test_data_qorc = qorc_quantum_layer(
    torch.tensor(test_data_pca_norm, dtype=torch.float32, device=compute_device)
)
time_t3 = time.time()

qorc_train_mean = train_data_qorc.detach().mean(dim=0)
qorc_train_std = train_data_qorc.detach().std(dim=0)

def normalize_standard_scaler(data, mean, std):
    epsilon = 1e-8
    return (data - mean) / (std + epsilon)

train_data_qorc_norm = normalize_standard_scaler(train_data_qorc, qorc_train_mean, qorc_train_std)
val_data_qorc_norm = normalize_standard_scaler(val_data_qorc, qorc_train_mean, qorc_train_std)
test_data_qorc_norm = normalize_standard_scaler(test_data_qorc, qorc_train_mean, qorc_train_std)


# =========================
# 6) Datasets / Dataloaders
# =========================
dtype = torch.float32
all_train_data = torch.cat(
    (torch.tensor(train_data, dtype=dtype, device=compute_device), train_data_qorc_norm), dim=1
)
all_val_data = torch.cat(
    (torch.tensor(val_data, dtype=dtype, device=compute_device), val_data_qorc_norm), dim=1
)
all_test_data = torch.cat(
    (torch.tensor(test_data, dtype=dtype, device=compute_device), test_data_qorc_norm), dim=1
)

ds_train = tensor_dataset(all_train_data, train_label, storage_device, dtype=torch.float32)
ds_val = tensor_dataset(all_val_data, val_label, storage_device, dtype=torch.float32)
ds_test = tensor_dataset(all_test_data, test_label, storage_device, dtype=torch.float32)

train_loader = get_dataloader(ds_train, batch_size, True, num_workers, pin_memory, seed)
val_loader = get_dataloader(ds_val, batch_size, False, num_workers, pin_memory, seed)
test_loader = get_dataloader(ds_test, batch_size, False, num_workers, pin_memory, seed)


# =========================
# 7) Linear classifier
# =========================
n_model_input_features = n_features_raw + qorc_output_size
logger.info("n_model_input_features: {}".format(n_model_input_features))

model = nn.Linear(n_model_input_features, n_classes, bias=True, device=compute_device)
nn.init.xavier_uniform_(model.weight)
nn.init.zeros_(model.bias)
model.to(compute_device)

criterion = nn.CrossEntropyLoss(reduction="sum")


# =========================
# 8) Training
# =========================
logger.info("Evaluation before training (on test set)")
model_eval(model, test_loader, criterion, compute_device, logger, True, True)

optimizer = torch.optim.Adagrad(model.parameters(), lr=learning_rate, eps=1e-7)

[
    train_loss_history,
    train_accuracy_history,
    val_loss_history,
    val_accuracy_history,
    duree_totale,
    best_val_epoch,
] = model_fit(
    model,
    train_loader,
    val_loader,
    criterion,
    optimizer,
    n_epochs,
    os.path.join(run_dir, f_out_weights),
    early_stop_patience=n_epochs,
    early_stop_min_delta=0.000001,
    reduce_lr_patience=reduce_lr_patience,
    reduce_lr_factor=reduce_lr_factor,
    device=compute_device,
    logger=logger,
    b_use_cosine_scheduler=False,
    calc_accuracy=True,
)
time_t4 = time.time()


# =========================
# 9) Final evaluation
# =========================
best_state_dict = torch.load(os.path.join(run_dir, f_out_weights), map_location=compute_device)
model.load_state_dict(best_state_dict)

_, train_acc, _ = model_eval(model, train_loader, criterion, compute_device, logger, True, True)
_, val_acc, _ = model_eval(model, val_loader, criterion, compute_device, logger, True, True)
_, test_acc, _ = model_eval(model, test_loader, criterion, compute_device, logger, True, True)
time_t5 = time.time()

logger.info("Duration - Quantum layer creation: {:.2f}s".format(time_t2 - time_t1))
logger.info("Duration - Quantum features encoding: {:.2f}s".format(time_t3 - time_t2))
logger.info("Duration - training: {:.2f}s".format(time_t4 - time_t3))
logger.info("Duration - total: {:.2f}s".format(time_t5 - time_t1))
logger.info("Best val epoch: {}".format(best_val_epoch))
logger.info("Accuracies - train: {:.4f}, val: {:.4f}, test: {:.4f}".format(train_acc, val_acc, test_acc))

# Detailed classification report on the test set (useful given class imbalance in NSL-KDD)
model.eval()
all_preds, all_true = [], []
with torch.no_grad():
    for inputs, labels in test_loader:
        outputs = model(inputs.to(compute_device))
        preds = torch.argmax(outputs, dim=1).cpu().numpy()
        all_preds.extend(preds)
        all_true.extend(labels.numpy())

print(classification_report(all_true, all_preds, target_names=[str(c) for c in class_names]))
cm = confusion_matrix(all_true, all_preds)
ConfusionMatrixDisplay(cm, display_labels=class_names).plot(cmap="Blues", xticks_rotation=45)
plt.tight_layout()
plt.savefig(run_dir / "confusion_matrix.png")
plt.show()
